[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    .venv,
    venv,
    env,
    .env
per-file-ignores =
    __init__.py:F401
    tests/*:D103
max-complexity = 10
select = E,W,F,C,N
docstring-convention = google